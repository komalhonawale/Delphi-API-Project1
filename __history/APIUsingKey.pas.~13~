unit APIUsingKey;

interface

uses
  Winapi.Windows, Winapi.Messages, System.SysUtils, System.Variants, System.Classes, Vcl.Graphics,
  Vcl.Controls, Vcl.Forms, Vcl.Dialogs, Vcl.StdCtrls, System.Net.HttpClient, System.Net.HttpClientComponent,   System.JSON;
  System.NetEncoding;

type
  TForm11 = class(TForm)
    edtUsername: TEdit;
    edtPassword: TEdit;
    btnCallAPI: TButton;
    MemoResult: TMemo;
    procedure btnCallAPIClick(Sender: TObject);
  private
    { Private declarations }
  public
    { Public declarations }
  end;

var
  Form11: TForm11;

implementation

{$R *.dfm}
procedure TForm11.btnCallAPIClick(Sender: TObject);
var
  HttpClient: TNetHTTPClient;
  Response: IHTTPResponse;
  Username, Password: string;
  AuthHeader: string;
  JsonObj: TJSONObject;
  IsAuthenticated: Boolean;
  LoggedInUser: string;
begin
  MemoResult.Clear;

  // 1️⃣ Read username & password
  Username := edtUsername.Text;
  Password := edtPassword.Text;

  if (Username = '') or (Password = '') then
  begin
    ShowMessage('Please enter Username and Password');
    Exit;
  end;

  // 2️⃣ Create Authorization header
  AuthHeader :=
    'Basic ' +
    TNetEncoding.Base64.Encode(Username + ':' + Password);

  // 3️⃣ Create HTTP client
  HttpClient := TNetHTTPClient.Create(nil);
  try
    HttpClient.CustomHeaders['Authorization'] := AuthHeader;

    // 4️⃣ Call API
    Response := HttpClient.Get(
      'https://httpbin.org/basic-auth/user/passwd'
    );

    MemoResult.Lines.Add('API RESPONSE:');
    MemoResult.Lines.Add(Response.ContentAsString);

    // 5️⃣ Parse JSON
    JsonObj :=
      TJSONObject.ParseJSONValue(
        Response.ContentAsString
      ) as TJSONObject;
    try
      if JsonObj = nil then
      begin
        ShowMessage('Invalid JSON response');
        Exit;
      end;

      // 6️⃣ Read JSON values (Delphi 10.2 compatible)
      IsAuthenticated :=
        JsonObj.GetValue('authenticated').AsBoolean;

      LoggedInUser :=
        JsonObj.GetValue('user').Value;

      // 7️⃣ CHECK SUCCESS
      if IsAuthenticated then
      begin
        MemoResult.Lines.Add('');
        MemoResult.Lines.Add('✅ LOGIN SUCCESS');
        MemoResult.Lines.Add('User: ' + LoggedInUser);

        ShowMessage('Login successful! Welcome ' + LoggedInUser);

        // 🔥 AFTER SUCCESS — CONTINUE YOUR APP HERE
        // Example:
        // Form2.Show;
        // Self.Hide;
      end
      else
      begin
        ShowMessage('❌ Authentication failed');
      end;

    finally
      JsonObj.Free;
    end;

  finally
    HttpClient.Free;
  end;
end;

end.
