function BuildExpression(A, B: Double; Op: Char): string;
begin
  Result := FloatToStr(A) + ' ' + Op + ' ' + FloatToStr(B);
end;

procedure TForm8.SaveHistory(const Expr, Res: string);
begin
  FDQuery1.Close;
  FDQuery1.SQL.Text :=
    'INSERT INTO CalcHistory (Expression, Result, CreatedAt) ' +
    'VALUES (:Expr, :Res, :CreatedAt)';

  FDQuery1.ParamByName('Expr').AsString := Expr;
  FDQuery1.ParamByName('Res').AsString := Res;
  FDQuery1.ParamByName('CreatedAt').AsString :=
    FormatDateTime('yyyy-mm-dd hh:nn:ss', Now);

  FDQuery1.ExecSQL;
end;


{---Equals---}
procedure TForm8.btnEqualsClick(Sender: TObject);
var
  Expr: string;
begin
  secondnum := StrToFloat(txtDisplay.Text);

  case opers of
    '+': answer := firstnum + secondnum;
    '-': answer := firstnum - secondnum;
    '*': answer := firstnum * secondnum;
    '/':
      begin
        if secondnum = 0 then
        begin
          ShowMessage('Cannot divide by zero');
          Exit;
        end;
        answer := firstnum / secondnum;
      end;
  end;

  txtDisplay.Text := FloatToStr(answer);
    Expr := FloatToStr(firstnum) + ' ' + opers + ' ' + FloatToStr(secondnum);
    SaveHistory(Expr, FloatToStr(answer));
end;



procedure TForm8.btnhistoryClick(Sender: TObject);
begin
  pnlCalculator.Visible := False;
  pnlHistory.Visible := True;
    pnlHistory.BringToFront;
end;

procedure TForm8.LoadHistory;
begin
  FDQueryHistory.Close;
  FDQueryHistory.SQL.Text :=
    'SELECT Expression, Result, CreatedAt ' +
    'FROM CalcHistory ' +
    'ORDER BY Id DESC ' +
    'LIMIT 10';

  FDQueryHistory.Open;
end;


procedure TForm8.btnDotClick(Sender: TObject);
